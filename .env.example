# RAG System Environment Variables
# Copy this file to .env and fill in your values

# LLM Provider API Keys (set the ones you plan to use)
GEMINI_API_KEY=
OPENROUTER_API_KEY=
FIREWORKS_API_KEY=
GROK_API_KEY=

# Server Configuration
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info

# Local Model Configuration
LOCAL_MODEL_PATH=models/model.gguf
N_GPU_LAYERS=0
N_THREADS=6
N_CTX=4096
